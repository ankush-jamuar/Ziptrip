// This file is required. Copy to .env and fill in your values.

# ─── Database ─────────────────────────────────────────────────────────────────
# Get your Neon PostgreSQL connection string from https://neon.tech
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-1.aws.neon.tech/taskflow?sslmode=require"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL (Vite dev server or Vercel deployment)
FRONTEND_URL=http://localhost:5173
